---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import ProductList from '~/components/products/ProductList.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  const paths = new Set(products.map((product) => `${product.data.kind}/${product.data.component_category}`));

  return Array.from(paths).map((path) => {
    const [kind, component] = path.split('/');
    return {
      params: { kind, component },
    };
  });
}

const { kind, component } = Astro.params;
const products = (await getCollection('products'))
  .filter((product) => product.data.kind === kind && product.data.component_category === component)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

function titleCaseSlug(value: string) {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function kindLabel(value: string) {
  return value === 'opensource' ? 'Open Source' : 'Commercial';
}

const kindName = kindLabel(kind ?? '');
const componentName = titleCaseSlug(component ?? '');
const title = `${kindName} ${componentName}`;
const recordLabel = products.length === 1 ? 'record' : 'records';
const intro = `Browse ${products.length} ${kindName.toLowerCase()} ${componentName.toLowerCase()} ${recordLabel} from the OpenSimGear product database. Each entry keeps its researched source links, availability details, compatibility notes, strengths, limitations, and original source note together so this category can be compared without losing the trail back to the JSON data.`;
---

<StarlightPage
  frontmatter={{
    title,
    description: `${title} records in the OpenSimGear third-party product database.`,
  }}
>
  <p>{intro}</p>
  <p>{products.length} records.</p>
  <ProductList products={products} headingLevel="h2" />
</StarlightPage>
