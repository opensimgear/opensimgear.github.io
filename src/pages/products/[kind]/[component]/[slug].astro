---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import ProductDetail from '~/components/products/ProductDetail.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');

  return products.map((product) => ({
    params: {
      kind: product.data.kind,
      component: product.data.component_category,
      slug: product.data.slug,
    },
    props: { product },
  }));
}

const { product } = Astro.props;

function titleCaseSlug(value: string) {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function kindLabel(value: string) {
  return value === 'opensource' ? 'Open Source' : 'Commercial';
}

function productName() {
  return product.data.product_name ?? product.data.project_name ?? '';
}

function productMaker() {
  return product.data.manufacturer ?? product.data.maker ?? '';
}

function compactTitle() {
  const maxTitleLength = 56;
  const name = productName();
  const maker = productMaker();
  const titleCandidates = [
    name,
    maker && name.startsWith(`${maker} `) ? name.replace(`${maker} `, '') : name,
  ].filter(Boolean);
  const matchingTitle = titleCandidates
    .filter((candidate) => candidate.length <= maxTitleLength)
    .sort((a, b) => b.length - a.length)[0];

  if (matchingTitle) return matchingTitle;

  return name.slice(0, maxTitleLength).replace(/\s+\S*$/, '');
}

const title = compactTitle();
const descriptionParts = [
  kindLabel(product.data.kind),
  titleCaseSlug(product.data.component_category),
  product.data.component_sub_category,
  productMaker(),
].filter(Boolean);
---

<StarlightPage
  frontmatter={{
    title,
    description: descriptionParts.join(' / '),
  }}
  headings={[
    { depth: 2, slug: 'links', text: 'Links' },
    { depth: 2, slug: 'shops', text: 'Shops' },
  ]}
>
  <ProductDetail product={product.data} />
</StarlightPage>
