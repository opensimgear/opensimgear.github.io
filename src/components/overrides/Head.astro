---
import Analytics from '~/components/util/Analytics.astro';
import { config } from '~/config';
import { buildDefaultSocialImageUrl, getSeoPolicy } from '~/utils/seo-policy';
import { buildTwitterMetaHead } from '~/utils/social-meta';
import { buildSiteSchemas } from '~/utils/structured-data';

const { head } = Astro.locals.starlightRoute;
const pathname = Astro.url.pathname;
const seoPolicy = getSeoPolicy(pathname);
const siteUrl = Astro.site?.toString();
const socialImageUrl = siteUrl ? buildDefaultSocialImageUrl(siteUrl) : undefined;
const siteSchemas = siteUrl
  ? buildSiteSchemas({
      site: siteUrl,
      title: config.brand.join(''),
      sameAs: [config.social.github, config.social.discord],
    })
  : [];

const filteredHead = head.filter(
  ({ tag, attrs }) => !(tag === 'meta' && attrs && 'name' in attrs && attrs.name === 'generator')
);

const hasOgImage = filteredHead.some(
  ({ tag, attrs }) => tag === 'meta' && attrs && 'property' in attrs && attrs.property === 'og:image'
);
const hasTwitterImage = filteredHead.some(
  ({ tag, attrs }) => tag === 'meta' && attrs && 'name' in attrs && attrs.name === 'twitter:image'
);
const hasRobots = filteredHead.some(
  ({ tag, attrs }) => tag === 'meta' && attrs && 'name' in attrs && attrs.name === 'robots'
);

const socialImageHead = socialImageUrl
  ? [
      ...(!hasOgImage ? [{ tag: 'meta', attrs: { property: 'og:image', content: socialImageUrl } }] : []),
      ...(!hasTwitterImage ? [{ tag: 'meta', attrs: { name: 'twitter:image', content: socialImageUrl } }] : []),
    ]
  : [];
const twitterMetaHead = buildTwitterMetaHead(filteredHead);

const routeSpecificHead =
  !hasRobots && (!seoPolicy.index || !seoPolicy.follow)
    ? [
        {
          tag: 'meta',
          attrs: {
            name: 'robots',
            content: `${seoPolicy.index ? 'index' : 'noindex'}, ${seoPolicy.follow ? 'follow' : 'nofollow'}`,
          },
        },
      ]
    : [];
---

{import.meta.env.PROD && <Analytics />}
{
  [...filteredHead, ...socialImageHead, ...twitterMetaHead, ...routeSpecificHead].map((entry) => {
    const Tag = entry.tag;
    const content = 'content' in entry ? entry.content : undefined;

    return <Tag {...entry.attrs} set:html={content} />;
  })
}
{siteSchemas.map((schema) => <script type="application/ld+json" is:inline set:html={schema} />)}
<slot />
