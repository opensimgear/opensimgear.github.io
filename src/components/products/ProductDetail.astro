---
import type { CollectionEntry } from 'astro:content';
import { productImages } from '~/data/3rdparty-product-images';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

type Product = CollectionEntry<'products'>['data'];

type Props = {
  product: Product;
};

const { product } = Astro.props;
const image = productImages[product.id] ?? githubOpenGraphImage(product);

function titleCaseSlug(value: string) {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function kindLabel(kind: string) {
  return kind === 'opensource' ? 'Open Source' : 'Commercial';
}

function productName(product: Product) {
  return product.product_name ?? product.project_name ?? '';
}

function makerName(product: Product) {
  return product.manufacturer ?? product.maker ?? '';
}

function primaryUrl(product: Product) {
  return product.kind === 'commercial' ? product.product_url : product.project_url;
}

function isHttpUrl(value: string | null | undefined): value is string {
  return typeof value === 'string' && /^https?:\/\//.test(value);
}

function githubOpenGraphImage(product: Product) {
  if (product.kind !== 'opensource') return null;

  if (!product.project_url) return null;

  try {
    const url = new URL(product.project_url);
    if (url.hostname !== 'github.com') return null;

    const [owner, repo] = url.pathname.split('/').filter(Boolean);
    if (!owner || !repo) return null;

    return {
      src: `https://opengraph.githubassets.com/1/${owner}/${repo}`,
    };
  } catch {
    return null;
  }
}

function formatPrice(price: number, currency: string) {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency,
    maximumFractionDigits: Number.isInteger(price) ? 0 : 2,
  }).format(price);
}

const overviewRows = [
  ['License', product.license],
].filter(([, value]) => value);

const productPageUrl = primaryUrl(product);

const breadcrumbItems = [
  {
    label: titleCaseSlug(product.component_category),
    href: `/products/?category=${encodeURIComponent(product.component_category)}`,
  },
  product.component_sub_category
    ? {
        label: titleCaseSlug(product.component_sub_category),
        href: `/products/?group=${encodeURIComponent(product.component_sub_category)}`,
      }
    : null,
].filter((item): item is { label: string; href: string } => Boolean(item));

const imageAlt = `${productName(product)} product photo`;
---

<WidgetWrapper containerClass="max-w-5xl">
<div class="grid gap-5">
  {makerName(product) && <h2 class="m-0 text-[1.2rem] font-[700] leading-tight">{makerName(product)}</h2>}

  <div class="flex flex-wrap items-center justify-between gap-3">
    <nav class="flex flex-wrap items-center gap-1 text-[0.76rem] font-[650] text-[var(--sl-color-gray-2)]" aria-label="Product category breadcrumb">
      {
        breadcrumbItems.map((item, index) => (
          <>
            {index > 0 && <span aria-hidden="true" class="text-[var(--sl-color-gray-3)]">&gt;</span>}
            <a
              class="rounded-none bg-transparent px-0 py-0 leading-none text-[var(--sl-color-gray-2)] no-underline underline-offset-4 hover:text-[var(--sl-color-accent-high)] hover:underline focus-visible:text-[var(--sl-color-accent-high)] focus-visible:underline"
              href={item.href}
              aria-label={`Filter by ${item.label}`}
            >
              {item.label}
            </a>
          </>
        ))
      }
    </nav>
    <div class="flex flex-wrap items-center justify-end gap-2">
      <span
        class:list={[
          'inline-flex whitespace-nowrap rounded-full px-3 py-1 text-[0.76rem] font-[700] leading-none',
          product.kind === 'commercial'
            ? 'bg-yellow-200 text-yellow-900'
            : 'bg-emerald-200 text-emerald-900',
        ]}
      >
        {kindLabel(product.kind)}
      </span>
    </div>
  </div>

  {
    image && (
  <figure class="m-0 grid justify-items-start gap-2">
    <img
      class="block max-h-[26rem] w-full max-w-[44rem] rounded-lg border border-[var(--sl-color-gray-5)] bg-white p-3 object-contain"
      src={image.src}
      alt={imageAlt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
        />
      </figure>
    )
  }

  {
    product.description && (
      <p class="m-0 text-[1rem] leading-[1.65] text-[var(--sl-color-gray-2)]">{product.description}</p>
    )
  }

  <div class="grid gap-3 [grid-template-columns:repeat(auto-fit,minmax(13rem,1fr))]">
    {
      overviewRows.map(([label, value]) => (
        <div class="rounded-lg border border-[var(--sl-color-gray-5)] p-[0.875rem]">
          <dt class="m-0 text-[0.8rem] font-semibold uppercase tracking-[0] text-[var(--sl-color-gray-3)]">{label}</dt>
          <dd class="mt-1 m-0">{value}</dd>
        </div>
      ))
    }
  </div>

  {
    isHttpUrl(productPageUrl) && (
      <div>
        <a
          class="inline-flex items-center gap-2 rounded-[10px] border border-[var(--sl-color-gray-5)] px-3 py-2 text-[0.82rem] font-[650] text-[var(--sl-color-text)] no-underline hover:border-[var(--sl-color-accent)] hover:text-[var(--sl-color-accent-high)]"
          href={productPageUrl}
          target="_blank"
          rel="noreferrer noopener"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M12 5H5v14h14v-7" />
            <path d="M14 5h5v5" />
            <path d="m10 14 9-9" />
          </svg>
          Product Page
        </a>
      </div>
    )
  }

  {
    product.kind === 'commercial' && (
      <>
        <h2 id="available-at">Available at</h2>
        {product.shops?.length ? (
          <div class="overflow-x-auto rounded-lg border border-[var(--sl-color-gray-5)]">
            <table class="m-0 w-full min-w-[28rem] border-collapse text-left text-[0.9rem]">
              <thead class="border-b border-[var(--sl-color-gray-5)] text-[0.76rem] uppercase tracking-[0] text-[var(--sl-color-gray-3)]">
                <tr>
                  <th class="px-4 py-3 font-[700]">Name</th>
                  <th class="px-4 py-3 text-right font-[700]">Price</th>
                  <th class="px-4 py-3 text-right font-[700]">Link</th>
                </tr>
              </thead>
              <tbody>
                {product.shops.map((shop) => (
                  <tr class="border-b border-[var(--sl-color-gray-6)] last:border-b-0">
                    <td class="px-4 py-3">{shop.name ?? 'Shop'}</td>
                    <td class="px-4 py-3 text-right font-[650]">{formatPrice(shop.price, shop.currency)}</td>
                    <td class="px-4 py-3 text-right">
                      {isHttpUrl(shop.url) && (
                        <a
                          class="ml-auto inline-flex h-8 w-8 items-center justify-center rounded-[8px] border border-[var(--sl-color-gray-5)] text-[var(--sl-color-gray-2)] no-underline hover:border-[var(--sl-color-accent)] hover:text-[var(--sl-color-accent-high)]"
                          href={shop.url}
                          target="_blank"
                          rel="noreferrer noopener"
                          aria-label={`Open ${shop.name ?? 'shop'} page`}
                        >
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                            <path d="M12 5H5v14h14v-7" />
                            <path d="M14 5h5v5" />
                            <path d="m10 14 9-9" />
                          </svg>
                        </a>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <p>No price available.</p>
        )}
      </>
    )
  }
</div>
</WidgetWrapper>
