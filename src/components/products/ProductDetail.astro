---
import type { CollectionEntry } from 'astro:content';
import { productImages } from '~/data/3rdparty-product-images';

type Product = CollectionEntry<'products'>['data'];

type Props = {
  product: Product;
};

const { product } = Astro.props;
const image = productImages[product.id];

function titleCaseSlug(value: string) {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function kindLabel(kind: string) {
  return kind === 'opensource' ? 'Open Source' : 'Commercial';
}

function fieldLabel(value: string) {
  return value
    .replaceAll('_', ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase())
    .replace('Url', 'URL')
    .replace('Bom', 'BOM');
}

function asList(value: unknown) {
  if (Array.isArray(value)) return value.filter(Boolean).map(String);
  if (typeof value === 'string' && value.trim()) return [value];
  return [];
}

const overviewRows = [
  ['Product Name', product.name],
  ['Type', kindLabel(product.kind)],
  ['Category', titleCaseSlug(product.component_category)],
  ['Subcategory', product.subcategory],
  ['Organization', product.organization.display],
  ['Status', product.availability.status ?? product.availability.maturity_or_status],
  ['Price / MSRP', product.availability.price_or_msrp],
  ['License', product.availability.license],
  ['Region / Availability', product.availability.region_or_availability],
  ['Last Checked', product.last_checked],
].filter(([, value]) => value);

const detailRows = Object.entries(product.raw_fields).filter(([field]) => field !== 'source_urls');
const sourceUrls = product.urls.sources.filter((url) => /^https?:\/\//.test(url));
const imageAlt = product.image?.alt ?? `${product.title || product.name} product photo`;
---

<section class="grid gap-5">
  {
    image && (
      <figure class="m-0 grid justify-items-start gap-2">
        <img
          class="block max-h-[26rem] w-full max-w-[44rem] rounded-lg border border-[var(--sl-color-gray-5)] bg-white p-3 object-contain"
          src={image.src}
          alt={imageAlt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
        />
        {product.image?.source_url && (
          <figcaption class="text-[0.85rem] text-[var(--sl-color-gray-3)]">
            Image source:{' '}
            <a href={product.image.source_url} rel="noreferrer" target="_blank">
              {product.image.source_type}
            </a>
          </figcaption>
        )}
      </figure>
    )
  }

  <div class="grid gap-3 [grid-template-columns:repeat(auto-fit,minmax(13rem,1fr))]">
    {
      overviewRows.map(([label, value]) => (
        <div class="rounded-lg border border-[var(--sl-color-gray-5)] p-[0.875rem]">
          <dt class="m-0 text-[0.8rem] font-semibold uppercase tracking-[0] text-[var(--sl-color-gray-3)]">{label}</dt>
          <dd class="mt-1 m-0">{value}</dd>
        </div>
      ))
    }
  </div>

  <h2 id="source-links">Source Links</h2>
  <ul class="[overflow-wrap:anywhere]">
    {
      sourceUrls.map((url) => (
        <li>
          <a href={url} target="_blank" rel="noreferrer noopener">
            {url}
          </a>
        </li>
      ))
    }
  </ul>

  <h2 id="research-fields">Research Fields</h2>
  <div class="grid gap-3">
    {
      detailRows.map(([field, value]) => (
        <section
          class="rounded-lg border border-[var(--sl-color-gray-5)] p-[0.875rem]"
          aria-labelledby={`${product.slug}-${field}`}
        >
          <h3 class="mb-2 mt-0 text-[0.95rem]" id={`${product.slug}-${field}`}>
            {fieldLabel(field)}
          </h3>
          {asList(value).length > 1 ? (
            <ul class="mb-0">
              {asList(value).map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          ) : (
            <p class="mb-0">{asList(value)[0]}</p>
          )}
        </section>
      ))
    }
  </div>

  <h2 id="source-note">Source Note</h2>
  <details class="rounded-lg border border-[var(--sl-color-gray-5)] p-[0.875rem]">
    <summary class="cursor-pointer font-semibold">Show original research markdown</summary>
    <pre class="mb-0 overflow-x-auto whitespace-pre-wrap"><code>{product.content_markdown}</code></pre>
  </details>
</section>
