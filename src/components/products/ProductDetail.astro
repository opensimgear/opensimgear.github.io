---
import type { CollectionEntry } from 'astro:content';
import { productImages } from '~/data/3rdparty-product-images';

type Product = CollectionEntry<'products'>['data'];

type Props = {
  product: Product;
};

const { product } = Astro.props;
const image = productImages[product.id];

function titleCaseSlug(value: string) {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function kindLabel(kind: string) {
  return kind === 'opensource' ? 'Open Source' : 'Commercial';
}

function productName(product: Product) {
  return product.product_name ?? product.project_name ?? '';
}

function makerName(product: Product) {
  return product.manufacturer ?? product.maker ?? '';
}

function primaryUrl(product: Product) {
  return product.kind === 'commercial' ? product.product_url : product.project_url;
}

function isHttpUrl(value: string | null | undefined): value is string {
  return typeof value === 'string' && /^https?:\/\//.test(value);
}

function formatPrice(price: number, currency: string) {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency,
    maximumFractionDigits: Number.isInteger(price) ? 0 : 2,
  }).format(price);
}

const overviewRows = [
  [product.kind === 'opensource' ? 'Project Name' : 'Product Name', productName(product)],
  ['Type', kindLabel(product.kind)],
  ['Category', titleCaseSlug(product.component_category)],
  ['Subcategory', product.component_sub_category],
  ['Maker', makerName(product)],
  ['License', product.license],
].filter(([, value]) => value);

const links = [
  {
    label: product.kind === 'commercial' ? 'Product URL' : 'Project URL',
    url: primaryUrl(product),
  },
  {
    label: 'Picture URL',
    url: product.picture_url,
  },
].filter((link): link is { label: string; url: string } => isHttpUrl(link.url));

const imageAlt = `${productName(product)} product photo`;
---

<section class="grid gap-5">
  {
    image ? (
      <figure class="m-0 grid justify-items-start gap-2">
        <img
          class="block max-h-[26rem] w-full max-w-[44rem] rounded-lg border border-[var(--sl-color-gray-5)] bg-white p-3 object-contain"
          src={image.src}
          alt={imageAlt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
        />
      </figure>
    ) : (
      isHttpUrl(product.picture_url) && (
        <figure class="m-0 grid justify-items-start gap-2">
          <img
            class="block max-h-[26rem] w-full max-w-[44rem] rounded-lg border border-[var(--sl-color-gray-5)] bg-white p-3 object-contain"
            src={product.picture_url}
            alt={imageAlt}
            loading="eager"
            decoding="async"
          />
        </figure>
      )
    )
  }

  {
    product.description && (
      <p class="m-0 text-[1rem] leading-[1.65] text-[var(--sl-color-gray-2)]">{product.description}</p>
    )
  }

  <div class="grid gap-3 [grid-template-columns:repeat(auto-fit,minmax(13rem,1fr))]">
    {
      overviewRows.map(([label, value]) => (
        <div class="rounded-lg border border-[var(--sl-color-gray-5)] p-[0.875rem]">
          <dt class="m-0 text-[0.8rem] font-semibold uppercase tracking-[0] text-[var(--sl-color-gray-3)]">{label}</dt>
          <dd class="mt-1 m-0">{value}</dd>
        </div>
      ))
    }
  </div>

  <h2 id="links">Links</h2>
  <ul class="[overflow-wrap:anywhere]">
    {
      links.map((link) => (
        <li>
          <strong>{link.label}: </strong>
          <a href={link.url} target="_blank" rel="noreferrer noopener">
            {link.url}
          </a>
        </li>
      ))
    }
  </ul>

  {
    product.kind === 'commercial' && (
      <>
        <h2 id="shops">Shops</h2>
        {product.shops?.length ? (
          <div class="grid gap-3">
            {product.shops.map((shop) => (
              <section class="rounded-lg border border-[var(--sl-color-gray-5)] p-[0.875rem]">
                <h3 class="mb-2 mt-0 text-[0.95rem]">{shop.region ?? 'Shop'}</h3>
                <p class="mb-2 mt-0 font-semibold">{formatPrice(shop.price, shop.currency)}</p>
                {shop.url && (
                  <a href={shop.url} target="_blank" rel="noreferrer noopener">
                    {shop.url}
                  </a>
                )}
              </section>
            ))}
          </div>
        ) : (
          <p>No numeric shop price is available in the YAML database.</p>
        )}
      </>
    )
  }
</section>
