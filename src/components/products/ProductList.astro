---
import type { CollectionEntry } from 'astro:content';
import { productImages } from '~/data/3rdparty-product-images';

type ProductEntry = CollectionEntry<'products'>;

type Props = {
  products: ProductEntry[];
  headingLevel?: 'h2' | 'h3';
  showKind?: boolean;
};

const { products, headingLevel = 'h3', showKind = false } = Astro.props;
const Heading = headingLevel;

function titleCaseSlug(value: string) {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function kindLabel(kind: string) {
  return kind === 'opensource' ? 'Open Source' : 'Commercial';
}

function productHref(product: ProductEntry['data']) {
  return `/products/${product.kind}/${product.component_category}/${product.slug}/`;
}

function productImage(product: ProductEntry['data']) {
  return productImages[product.id];
}

function productName(product: ProductEntry['data']) {
  return product.product_name ?? product.project_name ?? '';
}

function makerName(product: ProductEntry['data']) {
  return product.manufacturer ?? product.maker ?? '';
}

function primaryMeta(product: ProductEntry['data']) {
  return [
    showKind ? kindLabel(product.kind) : null,
    titleCaseSlug(product.component_category),
    product.component_sub_category,
    makerName(product),
  ].filter(Boolean);
}

function summary(product: ProductEntry['data']) {
  return product.description ?? product.license ?? null;
}
---

<div class="grid gap-3">
  {
    products.map(({ data: product }) => {
      const image = productImage(product);

      return (
        <article class="grid items-center gap-4 rounded-lg border border-[var(--sl-color-gray-5)] p-4 max-[40rem]:grid-cols-1 [grid-template-columns:minmax(5.5rem,7rem)_minmax(0,1fr)_auto]">
          {image && (
            <a
              class="grid aspect-[4/3] w-full place-items-center overflow-hidden rounded-md border border-[var(--sl-color-gray-6)] bg-white no-underline max-[40rem]:max-w-40"
              href={productHref(product)}
              aria-label={`View ${productName(product)}`}
            >
              <img
                class="block h-full w-full object-contain p-[0.3rem]"
                src={image.src}
                alt={`${productName(product)} product photo`}
                width={image.width}
                height={image.height}
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
          <div class="min-w-0">
            <Heading class="m-0 text-base leading-[1.35]">
              <a href={productHref(product)}>{productName(product)}</a>
            </Heading>
            <p class="mt-1 text-sm leading-[1.4] text-[var(--sl-color-gray-3)]">{primaryMeta(product).join(' / ')}</p>
            {summary(product) && (
              <p class="mt-2 text-[0.925rem] leading-[1.5] text-[var(--sl-color-gray-2)]">{summary(product)}</p>
            )}
          </div>
          <a
            class="whitespace-nowrap rounded-md border border-[var(--sl-color-gray-5)] px-3 py-2 text-sm leading-none text-[var(--sl-color-text)] no-underline hover:border-[var(--sl-color-accent)] hover:text-[var(--sl-color-accent-high)] max-[40rem]:justify-self-start"
            href={productHref(product)}
            aria-label={`View ${productName(product)}`}
          >
            View
          </a>
        </article>
      );
    })
  }
</div>
